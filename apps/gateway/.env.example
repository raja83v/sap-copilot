# SAP Copilot Gateway Configuration

# Server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
GATEWAY_DEBUG=true

# CORS (Vite dev server)
GATEWAY_CORS_ORIGINS=["http://localhost:5173"]

# VSP MCP Server
GATEWAY_VSP_PYTHON=python
GATEWAY_VSP_COMMAND=vsp

# LiteLLM Proxy
GATEWAY_LITELLM_BASE_URL=http://localhost:4000
GATEWAY_LITELLM_API_KEY=sk-1234
GATEWAY_LITELLM_DEFAULT_MODEL=

# Encryption key for SAP credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
GATEWAY_ENCRYPTION_KEY=

# Proxy for SAP connectivity
GATEWAY_HTTP_PROXY=http://proxy.det.nsw.edu.au:8080

# Timeouts (seconds)
GATEWAY_MCP_REQUEST_TIMEOUT_SEC=20
GATEWAY_MCP_TOOL_CALL_TIMEOUT_SEC=90
GATEWAY_TEST_CONNECTION_TIMEOUT_SEC=20
